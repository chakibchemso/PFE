import { Theme } from "../theme.slint";

/// Compass ring with needle for GPS page.
/// The caller positions this component; it only defines its own size and internal layout.
export component CompassRing inherits Rectangle {
    in property <float> needle_angle: 28;
    in property <bool> has_fix: false;

    width: 144px;
    height: 144px;

    // Outer ring
    Rectangle {
        x: 0;
        y: 0;
        width: parent.width;
        height: parent.height;
        border-radius: self.width / 2;
        background: Theme.mantle;
    }

    // Inner ring
    Rectangle {
        x: 18px;
        y: 18px;
        width: 108px;
        height: 108px;
        border-radius: self.width / 2;
        background: Theme.base;
        border-color: Theme.surface0;
        border-width: 1px;
    }

    // North indicator
    Rectangle {
        x: parent.width / 2 - 4px;
        y: 10px;
        width: 8px;
        height: 12px;
        border-radius: 4px;
        background: Theme.surface2;
    }

    // Compass needle
    Rectangle {
        x: parent.width / 2 - 4px;
        y: 32px;
        width: 8px;
        height: 40px;
        border-radius: 4px;
        background: Theme.accent;
        transform-origin: { x: 4px, y: 40px };
        transform-rotation: needle_angle * 1deg;
    }

    // Center dot (fix status)
    Rectangle {
        x: parent.width / 2 - 8px;
        y: parent.height / 2 - 6px;
        width: 16px;
        height: 16px;
        border-radius: 8px;
        background: has_fix ? Theme.green : Theme.peach;
    }
}
