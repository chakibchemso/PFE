import { Theme } from "../theme.slint";

/// Toggle switch with animated knob
export component ToggleSwitch inherits Rectangle {
    in property <bool> enabled: false;

    width: 46px;
    height: 28px;
    border-radius: 14px;
    background: enabled ? Theme.accent : Theme.surface1;

    Rectangle {
        x: enabled ? 22px : 3px;
        y: 3px;
        width: 22px;
        height: 22px;
        border-radius: 11px;
        background: Theme.mantle;
        animate x {
            duration: 160ms;
            easing: ease-in-out;
        }
    }
}
