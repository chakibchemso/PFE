import { Theme } from "../theme.slint";

/// Stat card with icon circle, label, and value
export component StatCard inherits Rectangle {
    in property <string> label: "";
    in property <string> value: "";
    in property <color> icon_color: Theme.accent;
    in property <length> card_width: 0px;

    width: card_width;
    height: 72px;
    border-radius: 20px;
    background: Theme.mantle;

    Rectangle {
        x: 14px;
        y: 16px;
        width: 40px;
        height: 40px;
        border-radius: 20px;
        background: icon_color;
    }

    Text {
        x: 64px;
        y: 10px;
        text: label;
        color: Theme.subtext;
        font-size: 13px;
    }

    Text {
        x: 64px;
        y: 28px;
        text: value;
        color: Theme.text;
        font-size: 24px;
        font-weight: 700;
    }
}
