import { Theme } from "theme.slint";
import { SettingsPage } from "widgets/settings.slint";
import { WatchfacePage } from "widgets/watchface.slint";
import { OxymeterPage } from "widgets/oxymeter.slint";
import { EcgPage } from "widgets/ecg.slint";
import { GpsPage } from "widgets/gps.slint";
import { PageIndicator } from "components/page_indicator.slint";

// FPS counter component that tracks frame rate
component FPSOverlay inherits Rectangle {
    in property <bool> show: false;

    property <int> frame_counter: 0;
    property <int> current_fps: 0;

    Timer {
        interval: 100ms;
        running: root.show;
        triggered => {
            root.frame_counter = root.frame_counter + 1;
        }
    }

    Timer {
        interval: 1000ms;
        running: root.show;
        triggered => {
            root.current_fps = root.frame_counter;
            root.frame_counter = 0;
        }
    }

    x: (466px - 68px) / 2;
    y: 466px - 20px;
    width: 68px;
    height: 16px;
    border-radius: 8px;
    background: {
        if (root.current_fps >= 50) {
            Theme.green
        } else if (root.current_fps >= 30) {
            Theme.yellow
        } else {
            Theme.red
        }
    };
    opacity: root.show ? 0.85 : 0;
    visible: root.show;

    Text {
        x: 0;
        y: 1px;
        width: parent.width;
        text: root.current_fps + " FPS";
        color: Theme.mantle;
        font-size: 10px;
        font-weight: 700;
        horizontal-alignment: center;
    }
}

export component SmartWatchUI inherits Window {
    width: 466px;
    height: 466px;
    background: Theme.base;

    in property <string> time: "--:--";
    in property <string> bpm: "--";
    in property <string> spo2: "--";
    in property <float> hour_angle: 330;
    in property <float> minute_angle: 24;
    in property <int> elapsed_seconds: 0;
    in property <bool> wifi_connected: false;
    in property <bool> ascon_secure: false;
    in property <bool> gps_fix: false;
    in property <float> gps_heading: 0.0;
    in property <string> gps_coords: "--";
    in property <string> gps_speed: "-- km/h";
    in property <string> gps_sats: "-- sats";
    in property <string> gps_altitude: "-- m";
    in-out property <bool> dark_mode <=> Theme.dark_mode;
    in-out property <bool> show_fps: false;

    property <int> active_page: 1;
    property <int> _prev_page: 1;
    property <length> drag_offset: 0px;
    property <bool> dragging: false;
    property <length> slide_x: -466px;

    // Snap animation duration: 0ms while dragging (instant), 250ms when released
    property <duration> snap_duration: 250ms;

    animate slide_x {
        duration: root.snap_duration;
        easing: ease-in-out;
    }

    changed active_page => {
        if (root.active_page != root._prev_page) {
            root.slide_x = 0px - root.active_page * root.width;
            root._prev_page = root.active_page;
        }
    }

    TouchArea {
        width: parent.width;
        height: parent.height;

        moved => {
            let dx = self.mouse-x - self.pressed-x;
            let dy = self.mouse-y - self.pressed-y;
            let abs_dx = dx < 0px ? -dx : dx;
            let abs_dy = dy < 0px ? -dy : dy;
            if (abs_dx > abs_dy && abs_dx > 8px) {
                root.dragging = true;
                root.drag_offset = dx;
                // Disable animation during drag for instant finger following
                root.snap_duration = 0ms;
                root.slide_x = 0px - root.active_page * root.width + dx;
            }
        }

        pointer-event(event) => {
            if (event.button == PointerEventButton.left && event.kind == PointerEventKind.up) {
                if (root.dragging) {
                    // Re-enable animation for snap
                    root.snap_duration = 250ms;
                    // Snap to nearest page based on drag offset
                    let threshold = root.width / 3;
                    if (root.drag_offset < -threshold && root.active_page < 4) {
                        root.active_page += 1;
                    } else if (root.drag_offset > threshold && root.active_page > 0) {
                        root.active_page -= 1;
                    } else {
                        // Snap back to current page
                        root.slide_x = 0px - root.active_page * root.width;
                    }
                }
                root.dragging = false;
                root.drag_offset = 0px;
            }
        }
    }

    Rectangle {
        x: root.slide_x;
        height: root.height;

        SettingsPage {
            x: 0px;
            width: root.width;
            height: root.height;
            dark_mode <=> root.dark_mode;
            show_fps <=> root.show_fps;
        }

        WatchfacePage {
            x: 466px;
            width: root.width;
            height: root.height;
            time: root.time;
            hour_angle: root.hour_angle;
            minute_angle: root.minute_angle;
            elapsed_seconds: root.elapsed_seconds;
            wifi_connected: root.wifi_connected;
            ascon_secure: root.ascon_secure;
        }

        OxymeterPage {
            x: 932px;
            width: root.width;
            height: root.height;
            bpm: root.bpm;
            spo2: root.spo2;
        }

        EcgPage {
            x: 1398px;
            width: root.width;
            height: root.height;
        }

        GpsPage {
            x: 1864px;
            width: root.width;
            height: root.height;
            gps_fix: root.gps_fix;
            gps_heading: root.gps_heading;
            gps_coords: root.gps_coords;
            gps_speed: root.gps_speed;
            gps_sats: root.gps_sats;
            gps_altitude: root.gps_altitude;
        }
    }

    PageIndicator {
        y: root.height - 26px;
        active_page: root.active_page;
        page_count: 5;
    }

    FPSOverlay {
        show: root.show_fps;
    }
}
