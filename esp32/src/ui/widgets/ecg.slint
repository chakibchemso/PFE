import { Theme } from "../theme.slint";

export component EcgPage inherits Rectangle {
    background: Theme.base;
    property <length> safe-inset: 48px;

    // Title
    Text {
        x: 0;
        y: safe-inset - 8px;
        width: parent.width;
        text: "ECG";
        color: Theme.text;
        font-size: 26px;
        font-weight: 700;
        horizontal-alignment: center;
    }

    // ECG waveform area
    Rectangle {
        x: parent.width / 2 - (parent.width - safe-inset * 2 - 16px) / 2;
        y: safe-inset + 28px;
        width: parent.width - safe-inset * 2 - 16px;
        height: 120px;
        border-radius: 20px;
        background: Theme.mantle;
    }

    // Simplified ECG waveform bars
    Rectangle {
        x: parent.width / 2 - 90px;
        y: safe-inset + 110px;
        width: 14px;
        height: 16px;
        border-radius: 7px;
        background: Theme.green;
    }

    Rectangle {
        x: parent.width / 2 - 72px;
        y: safe-inset + 102px;
        width: 14px;
        height: 24px;
        border-radius: 7px;
        background: Theme.green;
    }

    Rectangle {
        x: parent.width / 2 - 54px;
        y: safe-inset + 114px;
        width: 14px;
        height: 12px;
        border-radius: 6px;
        background: Theme.green;
    }

    Rectangle {
        x: parent.width / 2 - 36px;
        y: safe-inset + 88px;
        width: 14px;
        height: 38px;
        border-radius: 7px;
        background: Theme.green;
    }

    Rectangle {
        x: parent.width / 2 - 18px;
        y: safe-inset + 50px;
        width: 14px;
        height: 76px;
        border-radius: 7px;
        background: Theme.red;
    }

    Rectangle {
        x: parent.width / 2;
        y: safe-inset + 32px;
        width: 14px;
        height: 94px;
        border-radius: 7px;
        background: Theme.red;
    }

    Rectangle {
        x: parent.width / 2 + 18px;
        y: safe-inset + 78px;
        width: 14px;
        height: 48px;
        border-radius: 7px;
        background: Theme.green;
    }

    Rectangle {
        x: parent.width / 2 + 36px;
        y: safe-inset + 100px;
        width: 14px;
        height: 26px;
        border-radius: 7px;
        background: Theme.green;
    }

    Rectangle {
        x: parent.width / 2 + 54px;
        y: safe-inset + 92px;
        width: 14px;
        height: 34px;
        border-radius: 7px;
        background: Theme.green;
    }

    Rectangle {
        x: parent.width / 2 + 72px;
        y: safe-inset + 110px;
        width: 14px;
        height: 16px;
        border-radius: 7px;
        background: Theme.green;
    }

    // Status text
    Text {
        x: 0;
        y: parent.height - safe-inset;
        width: parent.width;
        text: "MAX30003 ready";
        color: Theme.subtext;
        font-size: 14px;
        horizontal-alignment: center;
    }
}
