import { Theme } from "../theme.slint";
import { StatusBadge } from "../components/status_badge.slint";

export component WatchfacePage inherits Rectangle {
    in property <string> time: "--:--";
    in property <float> hour_angle: 330;
    in property <float> minute_angle: 24;
    in property <int> elapsed_seconds: 0;
    in property <bool> wifi_connected: false;
    in property <bool> ascon_secure: true;
    in property <string> cpu_temp: "--°C";
    property <length> safe-inset: 48px;

    background: Theme.base;

    // Clock face ring
    Rectangle {
        x: parent.width / 2 - (parent.width - root.safe-inset * 2) / 2;
        y: parent.height / 2 - (parent.width - root.safe-inset * 2) / 2;
        width: parent.width - root.safe-inset * 2;
        height: parent.width - root.safe-inset * 2;
        border-radius: self.width / 2;
        background: Theme.mantle;
        border-color: Theme.surface1;
        border-width: 2px;
    }

    // Inner clock ring
    Rectangle {
        x: parent.width / 2 - 60px;
        y: parent.height / 2 - 60px;
        width: 120px;
        height: 120px;
        border-radius: self.width / 2;
        background: Theme.base;
        border-color: Theme.surface0;
        border-width: 1px;
    }

    // Cardinal markers
    Rectangle {
        x: parent.width / 2 - 6px;
        y: 56px;
        width: 12px;
        height: 22px;
        border-radius: 6px;
        background: Theme.surface2;
    }

    Rectangle {
        x: parent.width - 78px;
        y: parent.height / 2 - 6px;
        width: 22px;
        height: 12px;
        border-radius: 6px;
        background: Theme.surface2;
    }

    Rectangle {
        x: parent.width / 2 - 6px;
        y: parent.height - 78px;
        width: 12px;
        height: 22px;
        border-radius: 6px;
        background: Theme.surface2;
    }

    Rectangle {
        x: 56px;
        y: parent.height / 2 - 6px;
        width: 22px;
        height: 12px;
        border-radius: 6px;
        background: Theme.surface2;
    }

    // Hour hand
    Rectangle {
        x: parent.width / 2 - 3px;
        y: parent.height / 2 - 52px;
        width: 6px;
        height: 52px;
        border-radius: 3px;
        background: Theme.accent2;
        transform-origin: { x: 3px, y: 52px };
        transform-rotation: hour_angle * 1deg;
    }

    // Minute hand
    Rectangle {
        x: parent.width / 2 - 2px;
        y: parent.height / 2 - 70px;
        width: 4px;
        height: 70px;
        border-radius: 2px;
        background: Theme.accent;
        transform-origin: { x: 2px, y: 70px };
        transform-rotation: minute_angle * 1deg;
    }

    // Second hand
    Rectangle {
        x: parent.width / 2 - 1px;
        y: parent.height / 2 - 78px;
        width: 2px;
        height: 78px;
        border-radius: 1px;
        background: Theme.subtext;
        transform-origin: { x: 1px, y: 78px };
        transform-rotation: (Math.mod(elapsed_seconds, 60) * 6) * 1deg;
    }

    // Center dot
    Rectangle {
        x: parent.width / 2 - 6px;
        y: parent.height / 2 - 6px;
        width: 12px;
        height: 12px;
        border-radius: 6px;
        background: Theme.text;
    }

    // Digital time - centered, below center
    Text {
        x: 0;
        y: parent.height / 2 + 20px;
        width: parent.width;
        text: time;
        color: Theme.text;
        font-size: 38px;
        font-weight: 700;
        horizontal-alignment: center;
    }

    // Brand label at top
    Text {
        x: 0;
        y: safe-inset - 8px;
        width: parent.width;
        text: "One Watch";
        color: Theme.subtext;
        font-size: 14px;
        horizontal-alignment: center;
    }

    // WiFi status badge
    StatusBadge {
        x: parent.width / 2 - 76px;
        y: parent.height / 2 + 66px;
        label: wifi_connected ? "Wi-Fi On" : "Wi-Fi Off";
        active: wifi_connected;
    }

    // ASCON status badge
    StatusBadge {
        x: parent.width / 2 + 8px;
        y: parent.height / 2 + 66px;
        label: ascon_secure ? "ASCON" : "Plain";
        active: ascon_secure;
        active_color: Theme.accent;
    }

    // CPU die temperature
    Text {
        x: 0;
        y: parent.height / 2 + 90px;
        width: parent.width;
        text: "CPU " + cpu_temp;
        color: Theme.subtext;
        font-size: 11px;
        horizontal-alignment: center;
    }
}
