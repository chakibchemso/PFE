import { Theme } from "../theme.slint";
import { StatCard } from "../components/stat_card.slint";

export component OxymeterPage inherits Rectangle {
    in property <string> bpm: "--";
    in property <string> spo2: "--";
    property <length> safe-inset: 48px;
    property <length> card_width: 466px - safe-inset * 2 - 16px;

    background: Theme.base;

    // Title
    Text {
        x: 0;
        y: safe-inset - 8px;
        width: parent.width;
        text: "Vitals";
        color: Theme.text;
        font-size: 26px;
        font-weight: 700;
        horizontal-alignment: center;
    }

    // Heart Rate card
    StatCard {
        x: parent.width / 2 - card_width / 2;
        y: safe-inset + 28px;
        label: "Heart Rate";
        value: bpm + " bpm";
        icon_color: Theme.red;
        card_width: root.card_width;
    }

    // SpO2 card
    StatCard {
        x: parent.width / 2 - card_width / 2;
        y: safe-inset + 112px;
        label: "SpO2";
        value: spo2 + " %";
        icon_color: Theme.sky;
        card_width: root.card_width;
    }

    // Progress bar
    Rectangle {
        x: parent.width / 2 - card_width / 2;
        y: safe-inset + 196px;
        width: card_width;
        height: 6px;
        border-radius: 3px;
        background: Theme.surface0;
    }

    Rectangle {
        x: parent.width / 2 - card_width / 2;
        y: safe-inset + 196px;
        width: card_width * 0.72;
        height: 6px;
        border-radius: 3px;
        background: Theme.green;
    }
}
